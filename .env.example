# ============================================================
# Microsoft AI 365 - Environment Variables
# ============================================================
# Copy this file to `.env` for local development.
# In production (GitHub Actions), set these as repository Secrets.
#
# Required:
# ============================================================

# ローカル開発: az login 後はAPIキー不要。DefaultAzureCredential が AzureCLICredential を自動使用。
# GitHub Actions: AZURE_CLIENT_ID / AZURE_TENANT_ID / AZURE_CLIENT_SECRET を Secrets に設定。

# Resource endpoint - MUST end with "/openai/v1/"
# Example: https://daka1-ai365-eastus2.openai.azure.com/openai/v1/
AZURE_OPENAI_BASE_URL=https://YOUR-RESOURCE.openai.azure.com/openai/v1/

# Your model deployment name (NOT the model name!)
# Example: "gpt-5-4-mini" or whatever you named your deployment
AZURE_OPENAI_DEPLOYMENT=gpt-5-4-mini
